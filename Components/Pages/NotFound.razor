@page "/not-found"
@layout MainLayout

<PageTitle>404 - Page Not Found | Neel Keshruwala</PageTitle>
<HeadContent>
    <meta name="robots" content="noindex, follow" />
</HeadContent>

<div class="not-found-container">
    <h1 class="not-found-code">404</h1>
    <p class="not-found-message">Page not found</p>
    <a href="/" class="btn-gold">Go Home</a>
</div>

<style>
    .not-found-container {
        min-height: 60vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 2rem;
    }
    .not-found-code {
        font-size: 8rem;
        font-weight: 700;
        color: var(--gold);
        margin: 0;
    }
    .not-found-message {
        font-size: 1.5rem;
        margin-bottom: 2rem;
    }
</style>